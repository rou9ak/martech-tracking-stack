# ═══════════════════════════════════════════════════════════════════════════════
# MARTECH TRACKING STACK — CREDENTIALS
# ═══════════════════════════════════════════════════════════════════════════════
# Instructions: See docs/hosting-credentials-guide.docx for where to find each value.
# NEVER commit this file. Verify .env is in .gitignore before every commit.
# ═══════════════════════════════════════════════════════════════════════════════


# ─── STAPE (sGTM Hosting) ─────────────────────────────────────────────────────
# Your first-party server domain (configured in Stape dashboard)
# Used as transport_url in GTM Web Google Tag
STAPE_CONTAINER_URL=https://collect.yourdomain.com


# ─── Google Tag Manager ───────────────────────────────────────────────────────
# GTM → Admin → Container Settings → Container ID
GTM_WEB_CONTAINER_ID=GTM-
GTM_SERVER_CONTAINER_ID=GTM-


# ─── GA4 ──────────────────────────────────────────────────────────────────────
# GA4 Admin → Data Streams → your stream → Measurement ID
GA4_MEASUREMENT_ID=G-

# GA4 Admin → Data Streams → your stream → Measurement Protocol API secrets
# SERVER-SIDE ONLY — never use client-side
GA4_API_SECRET=


# ─── Google Ads ───────────────────────────────────────────────────────────────
# Top-right of ads.google.com, remove hyphens (123-456-7890 → 1234567890)
GADS_CUSTOMER_ID=

# Goals → Conversions → click action → Tag setup (format: AW-XXXXXXXXX)
# Same for all conversion actions in the account
GADS_CONVERSION_ID=AW-

# Unique per conversion action — get one per lifecycle stage
GADS_LABEL_LEAD=
GADS_LABEL_MQL=
GADS_LABEL_SQL=
GADS_LABEL_CLOSED_WON=

# Google Ads API (for offline conversion uploads)
# Apply at: developers.google.com/google-ads/api/docs/first-call/overview
GADS_DEVELOPER_TOKEN=
GADS_CLIENT_ID=
GADS_CLIENT_SECRET=
GADS_REFRESH_TOKEN=


# ─── Meta ─────────────────────────────────────────────────────────────────────
# Events Manager → your pixel → header number (16 digits)
META_PIXEL_ID=

# Events Manager → pixel → Settings → Conversions API → Generate access token
# Real-time server-side events (EAA... token)
META_CAPI_TOKEN=

# Events Manager → Offline data source → Dataset ID (for CRM conversion uploads)
META_DATASET_ID=

# Business Settings → System Users → Generate token (ads_management permission)
# Used for offline conversion batch uploads
META_OFFLINE_TOKEN=

# Events Manager → Test Events → Server events tab
# DEVELOPMENT ONLY — remove this line in production
META_TEST_CODE=


# ─── LinkedIn ─────────────────────────────────────────────────────────────────
# Campaign Manager → Account Assets → Insight Tag (7-digit number)
LI_PARTNER_ID=

# Campaign Manager URL: /accounts/XXXXXXXXX (9-digit number)
LI_ACCOUNT_ID=

# LinkedIn Developer Portal → your app → Auth → OAuth 2.0 token
# WARNING: expires after 60 days — implement refresh token rotation for production
LI_ACCESS_TOKEN=

# Campaign Manager → Analyze → Conversion tracking → each conversion → ID
LI_CONV_LEAD=
LI_CONV_MQL=
LI_CONV_CUSTOMER=


# ─── HubSpot ──────────────────────────────────────────────────────────────────
# Settings → Private Apps → your app → Access token (pat-...)
HUBSPOT_ACCESS_TOKEN=

# Settings → Private Apps → your app → Auth tab → Client Secret
# Used to verify incoming webhook HMAC signature
HUBSPOT_CLIENT_SECRET=


# ─── Snowflake ────────────────────────────────────────────────────────────────
# Bottom-left username menu → Account (format: xy12345.us-east-1)
SNOWFLAKE_ACCOUNT=

# Use the service account created via CREATE USER svc_martech
SNOWFLAKE_USERNAME=svc_martech
SNOWFLAKE_PASSWORD=

SNOWFLAKE_DATABASE=PROD
SNOWFLAKE_SCHEMA=ANALYTICS
SNOWFLAKE_WAREHOUSE=TRANSFORMING_WH


# ─── Optional: Slack alerts ───────────────────────────────────────────────────
# Create at: api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
